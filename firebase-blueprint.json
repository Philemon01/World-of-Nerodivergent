{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "moderator", "content_creator", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Blog Post",
      "description": "Articles, tips, and community news.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "coverImage": { "type": "string" },
        "authorId": { "type": "string" },
        "category": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "authorId", "published", "createdAt"]
    },
    "Book": {
      "title": "Book product",
      "description": "Original resources and books for sale.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "coverImage": { "type": "string" },
        "previewImages": { "type": "array", "items": { "type": "string" } },
        "storeUrl": { "type": "string" },
        "published": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "published", "createdAt"]
    },
    "Resource": {
      "title": "Downloadable Resource",
      "description": "Guides, checklists, and PDFs for the community.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "guide", "checklist", "infographic"] },
        "fileUrl": { "type": "string" },
        "isFree": { "type": "boolean" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "fileUrl", "published", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Public blog posts."
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Books for sale."
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Community resources."
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "User purchase history."
    }
  }
}
