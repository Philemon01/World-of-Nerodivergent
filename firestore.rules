rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == 'admin') ||
        (request.auth.token.email == 'progressphilemon@gmail.com' && request.auth.token.email_verified == true));
    }

    function isModerator() {
      return isSignedIn() && (isAdmin() || getUserData().role == 'moderator');
    }

    function isContentCreator() {
      return isSignedIn() && (isAdmin() || getUserData().role == 'content_creator');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection Rules ---

    // USERS
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'createdAt', 'updatedAt']) &&
               data.keys().size() <= 7 &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['admin', 'moderator', 'content_creator', 'user'] &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    (incoming().role == 'user' || (incoming().role == 'admin' && isAdmin()));
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) || 
                    isAdmin();
      allow delete: if isAdmin();
    }

    // POSTS
    match /posts/{postId} {
      function isValidPost(data) {
        return data.keys().hasAll(['title', 'slug', 'content', 'excerpt', 'coverImage', 'authorId', 'category', 'published', 'createdAt', 'updatedAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.slug is string && data.slug.size() <= 200 &&
               data.content is string && data.content.size() <= 100000 &&
               data.excerpt is string && data.excerpt.size() <= 1000 &&
               data.coverImage is string && data.coverImage.size() <= 2000 &&
               data.authorId == request.auth.uid &&
               data.category is string &&
               data.published is bool &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }

      allow read, list: if (resource.data.published == true) || isModerator() || isContentCreator();
      allow create: if isContentCreator() && isValidPost(incoming());
      allow update: if (isContentCreator() && isValidPost(incoming())) || isModerator();
      allow delete: if isAdmin() || (isModerator() && existing().published == false);
    }

    // BOOKS
    match /books/{bookId} {
      function isValidBook(data) {
        return data.keys().hasAll(['title', 'description', 'price', 'currency', 'coverImage', 'storeUrl', 'published', 'order', 'createdAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 5000 &&
               data.price is number &&
               data.currency is string &&
               data.coverImage is string &&
               data.storeUrl is string &&
               data.published is bool &&
               data.order is number &&
               data.createdAt is timestamp;
      }

      allow read, list: if existing().published == true || isAdmin();
      allow create: if isAdmin() && isValidBook(incoming());
      allow update: if isAdmin() && isValidBook(incoming());
      allow delete: if isAdmin();
    }

    // PURCHASES
    match /purchases/{purchaseId} {
      allow read, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin(); // Only system/admin can record purchases
    }

    // RESOURCES
    match /resources/{resourceId} {
      function isValidResource(data) {
        return data.keys().hasAll(['title', 'description', 'type', 'fileUrl', 'isFree', 'published', 'createdAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 2000 &&
               data.type in ['pdf', 'guide', 'checklist', 'infographic'] &&
               data.fileUrl is string && data.fileUrl.size() <= 2000 &&
               data.isFree is bool &&
               data.published is bool &&
               data.createdAt is timestamp;
      }

      allow read, list: if existing().published == true || isAdmin();
      allow create, update, delete: if isAdmin() && isValidResource(incoming());
    }
  }
}
